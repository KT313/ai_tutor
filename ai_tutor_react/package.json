{
  "name": "ai-tutor-react",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n client,server -c blue,green \"vite\" \"tsx watch server/server.ts\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/server.ts",
    "build": "tsc -b && vite build",
    "preview": "concurrently -n preview,server -c blue,green \"vite preview\" \"tsx server/server.ts\"",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "dompurify": "^3.4.0",
    "hono": "^4.12.14",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  }
}
